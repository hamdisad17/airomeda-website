# === Plan 1 ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Error tracking (Sentry, optional but recommended for prod) ===
# Without these set, Sentry SDK loads but stays disabled.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# === Plan 3 (placeholder — wired when forms ship) ===

# SMTP for transactional mail (Hostinger / Mailgun / Resend / SES)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=hello@airomeda.com
# SMTP_PASS=
# MAIL_FROM=Airomeda <hello@airomeda.com>
# CONTACT_TO=sales@airomeda.com
# CAREERS_TO=careers@airomeda.com

# Cloudflare Turnstile (free, platform-agnostic spam protection)
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# CV upload storage (S3-compatible: AWS S3 / Cloudflare R2 / Hostinger Object Storage)
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=airomeda-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
