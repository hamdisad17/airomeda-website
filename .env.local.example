# Airomeda — local dev environment variables.
# Copy to .env.local and fill in. Production values live in
# /var/www/airomeda/shared/.env.production on the VPS (see deploy/SETUP_ENV.md).

# === Core ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Error tracking (Sentry, optional but recommended for prod) ===
# Without these set, Sentry SDK loads but stays disabled.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# === Forms — SMTP (Hostinger / Mailgun / Resend / SES) ===
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=hello@airomeda.com
# SMTP_PASS=
# MAIL_FROM=Airomeda <hello@airomeda.com>
# CONTACT_TO=sales@airomeda.com
# CAREERS_TO=careers@airomeda.com

# === Forms — Cloudflare Turnstile (spam protection) ===
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# === Lead persistence (SQLite via better-sqlite3) ===
# Absolute path to the SQLite file. Must be writable by the PM2 user.
# In dev, leave unset — falls back to ./.local-db/airomeda.db (gitignored).
# AIROMEDA_DB_PATH=/var/www/airomeda/shared/leads.db

# === Admin endpoint (basic auth on /api/admin/leads) ===
# Both must be set; otherwise the endpoint returns 401 for every request.
# ADMIN_USER=
# ADMIN_PASS=

# === CV upload storage (job application form) ===
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=airomeda-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# === Backup script (scripts/backup.sh) — optional remote upload ===
# Without these the script still writes a local tarball under
# /var/backups/airomeda/.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BACKUP_S3_BUCKET=
# BACKUP_S3_ENDPOINT=    # only for non-AWS S3 (e.g. R2 / Hostinger)
# BACKUP_RETENTION_DAYS=30
